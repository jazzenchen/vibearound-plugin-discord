{
  "id": "discord",
  "name": "Discord Channel",
  "version": "0.1.0",
  "kind": "channel",
  "runtime": "node",
  "entry": "dist/main.js",
  "build": "npm install && npm run build",
  "minHostVersion": "0.1.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "bot_token": { "type": "string", "description": "Discord Bot Token" }
    },
    "required": ["bot_token"]
  },
  "capabilities": {
    "streaming": true,
    "interactiveCards": false,
    "editMessage": true,
    "media": true
  }
}
